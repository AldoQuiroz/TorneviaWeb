@page "/mi-perfil"
@using TorneviaWeb.Models
@using Microsoft.EntityFrameworkCore
@using TorneviaWeb.Components.Shared
@inject TorneviaDbContext DbContext
@inject SesionUsuario Sesion
@inject NavigationManager Navigation

<PageTitle>Tornevia - Mi Perfil</PageTitle>

@if (!Sesion.EstaAutenticado)
{
    <p>No has iniciado sesión. <a href="/login">Ir al login</a></p>
}
else if (jugador == null)
{
    <p>No se encontró un perfil de jugador asociado a esta cuenta.</p>
}
else
{
    <div class="perfil-container">

        <div class="perfil-header">
            <div class="perfil-header-marca">
                <LogoTornevia ClaseAdicional="tamano-header" />
                <strong>TORNEVIA</strong>
            </div>
            <div class="perfil-header-usuario">
                @Sesion.Nombre &nbsp;
                <button class="btn-tornevia" @onclick="CerrarSesion">Cerrar sesión</button>
            </div>
        </div>

        <div class="perfil-body">

            <div class="perfil-sidebar">
                @if (!string.IsNullOrWhiteSpace(jugador.Equipo?.Logo))
                {
                    <div class="perfil-sidebar-banner">
                        <img src="@jugador.Equipo!.Logo" alt="Logo @jugador.Equipo.Nombre_Equipo" />
                    </div>
                }
                else
                {
                    <div class="perfil-sidebar-banner-vacio"></div>
                }
                <div class="perfil-sidebar-info">
                    <strong>@jugador.Nombre_Jugador</strong><br />
                    <span class="perfil-sidebar-posicion">@jugador.Posicion</span><br />
                    <span class="perfil-sidebar-equipo">🛡️ @jugador.Equipo?.Nombre_Equipo</span>
                </div>

                <div class="perfil-menu">
                    <div class="perfil-menu-item-activo">👤 Mi Perfil</div>
                    <div class="perfil-menu-item" @onclick="IrAMisEstadisticas">📊 Mis Estadísticas</div>
                    <div class="perfil-menu-item" @onclick="IrACalendario">📅 Calendario</div>
                    <div class="perfil-menu-item" @onclick="IrANoticias">📰 Noticias</div>
                </div>
            </div>

            <div class="perfil-content">
                <div class="perfil-stats-row">
                    <div class="perfil-stat-card">
                        <div class="perfil-stat-valor perfil-color-goles">@totalGoles</div>
                        <div class="perfil-stat-label">Goles</div>
                    </div>
                    <div class="perfil-stat-card">
                        <div class="perfil-stat-valor perfil-color-asistencias">@totalAsistencias</div>
                        <div class="perfil-stat-label">Asistencias</div>
                    </div>
                    <div class="perfil-stat-card">
                        <div class="perfil-stat-valor perfil-color-partidos">@totalPartidos</div>
                        <div class="perfil-stat-label">Partidos</div>
                    </div>
                    <div class="perfil-stat-card">
                        <div class="perfil-stat-valor perfil-color-amarillas">@totalAmarillas</div>
                        <div class="perfil-stat-label">T. Amarillas</div>
                    </div>
                </div>

                <div class="perfil-historial-card">
                    <strong>📄 Historial de Partidos</strong>
                    <table class="tabla-detalle" style="margin-top:10px;">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Partido</th>
                                <th>Goles</th>
                                <th>Asistencias</th>
                                <th>Resultado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fila in historial)
                            {
                                <tr>
                                    <td>@fila.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@fila.Rival</td>
                                    <td>@fila.Goles</td>
                                    <td>@fila.Asistencias</td>
                                    <td>
                                        @{
                                            var clasePill = fila.Resultado == "Victoria" ? "pill-victoria" :
                                            fila.Resultado == "Empate" ? "pill-empate" : "pill-derrota";
                                        }
                                        <span class="pill @clasePill">@fila.Resultado</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Jugador? jugador;
    private int totalGoles, totalAsistencias, totalPartidos, totalAmarillas;
    private List<FilaHistorial> historial = new();

    private class FilaHistorial
    {
        public DateTime Fecha { get; set; }
        public string Rival { get; set; } = string.Empty;
        public int Goles { get; set; }
        public int Asistencias { get; set; }
        public string Resultado { get; set; } = string.Empty;
    }

    protected override void OnInitialized()
    {
        if (!Sesion.EstaAutenticado || Sesion.ID_Usuario == null)
        {
            return;
        }

        jugador = DbContext.Jugadores
            .Include(j => j.Equipo)
            .FirstOrDefault(j => j.ID_Usuario == Sesion.ID_Usuario);

        if (jugador == null) return;

        var estadisticas = DbContext.Estadisticas
            .Include(e => e.Partido)
            .Where(e => e.ID_Jugador == jugador.ID_Jugador)
            .ToList();

        totalGoles = estadisticas.Sum(e => e.Goles);
        totalAsistencias = estadisticas.Sum(e => e.Asistencias);
        totalAmarillas = estadisticas.Sum(e => e.Tarjetas_Amarillas);
        totalPartidos = estadisticas.Count;

        foreach (var est in estadisticas)
        {
            if (est.Partido == null) continue;

            bool esLocal = est.Partido.Equipo_Local == jugador.ID_Equipo;
            int idEquipoRival = esLocal ? est.Partido.Equipo_Visitante : est.Partido.Equipo_Local;
            var equipoRival = DbContext.Equipos.FirstOrDefault(e => e.ID_Equipo == idEquipoRival);

            int golesEquipo = esLocal ? est.Partido.Goles_Local : est.Partido.Goles_Visitante;
            int golesRival = esLocal ? est.Partido.Goles_Visitante : est.Partido.Goles_Local;

            string resultado = golesEquipo > golesRival ? "Victoria" :
                                golesEquipo == golesRival ? "Empate" : "Derrota";

            historial.Add(new FilaHistorial
            {
                Fecha = est.Partido.Fecha,
                Rival = $"vs {equipoRival?.Nombre_Equipo ?? "Desconocido"}",
                Goles = est.Goles,
                Asistencias = est.Asistencias,
                Resultado = resultado
            });
        }

        historial = historial.OrderByDescending(h => h.Fecha).ToList();
    }

    private void CerrarSesion()
    {
        Sesion.CerrarSesion();
        Navigation.NavigateTo("/login");
    }
    private void IrAMisEstadisticas()
    {
        Navigation.NavigateTo("/mis-estadisticas");
    }
    private void IrACalendario()
    {
        Navigation.NavigateTo("/calendario");
    }
    private void IrANoticias()
    {
        Navigation.NavigateTo("/noticias");
    }
}