@page "/admin/equipos"
@using TorneviaWeb.Models
@using Microsoft.EntityFrameworkCore
@inject TorneviaDbContext DbContext
@inject SesionUsuario Sesion
@inject NavigationManager Navigation

<PageTitle>Tornevia - Gestión de Equipos</PageTitle>

@if (!Sesion.EstaAutenticado)
{
    <p class="sin-datos">No has iniciado sesión. <a href="/login">Ir al login</a></p>
}
else if (!Sesion.EsAdministrador)
{
    <p class="sin-datos">No tienes permisos de administrador para acceder a esta sección. <a href="/mi-perfil">Volver a Mi Perfil</a></p>
}
else
{
    <div class="stats-container">

        <div class="stats-header">
            <h2>🛡️ Gestión de Equipos</h2>
            <button class="btn-tornevia" @onclick="VolverPanel">← Volver al Panel</button>
        </div>

        <div class="stats-body">

            @if (!mostrarFormulario)
            {
                <button class="btn-primario" @onclick="MostrarFormularioNuevo">+ Registrar Nuevo Equipo</button>
            }

            @if (mostrarFormulario)
            {
                <EditForm Model="formModel" OnValidSubmit="GuardarEquipo" class="admin-form">
                    <DataAnnotationsValidator />

                    <div class="admin-form-titulo">@(modoEdicion ? "Editar Equipo" : "Registrar Nuevo Equipo")</div>

                    <div class="admin-form-grid">
                        <div class="admin-form-campo">
                            <label class="login-label">Nombre del equipo *</label>
                            <InputText class="login-input" maxlength="100" @bind-Value="formModel.Nombre_Equipo" placeholder="Ej: Los Cóndores" />
                        </div>

                        <div class="admin-form-campo">
                            <label class="login-label">Categoría</label>
                            <InputText class="login-input" maxlength="50" @bind-Value="formModel.Categoria" placeholder="Ej: Adulto, Senior, Sub-20" />
                        </div>

                        <div class="admin-form-campo admin-form-campo-full">
                            <label class="login-label">Logo (URL, debe ser una imagen .png)</label>
                            <div class="admin-logo-row">
                                <InputText class="login-input" maxlength="255" @bind-Value="formModel.Logo" placeholder="https://.../logo.png" />
                                @if (LogoEsValido(formModel.Logo))
                                {
                                    <img src="@formModel.Logo" class="admin-logo-preview" alt="Vista previa del logo" />
                                }
                                else if (!string.IsNullOrWhiteSpace(formModel.Logo))
                                {
                                    <span class="admin-logo-preview admin-logo-preview-error" title="La URL no es válida o no termina en .png">✕</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(mensajeError))
                    {
                        <div class="login-error">@mensajeError</div>
                    }

                    <div class="admin-form-acciones">
                        <button type="submit" class="btn-primario">Guardar</button>
                        <button type="button" class="btn-tornevia" @onclick="CancelarFormulario">Cancelar</button>
                    </div>
                </EditForm>
            }

            @if (!string.IsNullOrEmpty(mensajeExito))
            {
                <div class="login-exito">@mensajeExito</div>
            }

            <table class="tabla-detalle" style="margin-top:20px;">
                <thead>
                    <tr>
                        <th>Logo</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Jugadores</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (equipos.Count == 0)
                    {
                        <tr><td colspan="5" class="sin-datos">Aún no hay equipos registrados.</td></tr>
                    }
                    else
                    {
                        @foreach (var equipo in equipos)
                        {
                            <tr>
                                <td>
                                    @if (LogoEsValido(equipo.Logo))
                                    {
                                        <img src="@equipo.Logo" class="tabla-logo-equipo" alt="Logo @equipo.Nombre_Equipo" />
                                    }
                                    else
                                    {
                                        <span class="tabla-logo-placeholder">🛡️</span>
                                    }
                                </td>
                                <td>@equipo.Nombre_Equipo</td>
                                <td>@(string.IsNullOrEmpty(equipo.Categoria) ? "-" : equipo.Categoria)</td>
                                <td>@ObtenerCantidadJugadores(equipo.ID_Equipo)</td>
                                <td>
                                    <div class="admin-acciones-tabla">
                                        <button class="btn-tornevia" @onclick="() => EditarEquipo(equipo)">Editar</button>

                                        @if (idPendienteEliminar == equipo.ID_Equipo)
                                        {
                                            <span class="admin-confirmar-texto">¿Confirmar?</span>
                                            <button class="btn-peligro" @onclick="() => ConfirmarEliminarEquipo(equipo.ID_Equipo)">Sí, eliminar</button>
                                            <button class="btn-tornevia" @onclick="CancelarEliminar">No</button>
                                        }
                                        else
                                        {
                                            <button class="btn-peligro" @onclick="() => SolicitarEliminarEquipo(equipo.ID_Equipo)">Eliminar</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Equipo> equipos = new();
    private Dictionary<int, int> jugadoresPorEquipo = new();
    private EquipoFormModel formModel = new();
    private bool mostrarFormulario = false;
    private bool modoEdicion = false;
    private int? idPendienteEliminar = null;
    private string? mensajeError;
    private string? mensajeExito;

    private class EquipoFormModel
    {
        public int ID_Equipo { get; set; }
        public string Nombre_Equipo { get; set; } = string.Empty;
        public string? Categoria { get; set; }
        public string? Logo { get; set; }
    }

    protected override void OnInitialized()
    {
        if (!Sesion.EstaAutenticado || !Sesion.EsAdministrador) return;
        CargarEquipos();
    }

    private void CargarEquipos()
    {
        equipos = DbContext.Equipos.OrderBy(e => e.Nombre_Equipo).ToList();

        jugadoresPorEquipo = DbContext.Jugadores
            .GroupBy(j => j.ID_Equipo)
            .Select(g => new { IdEquipo = g.Key, Cantidad = g.Count() })
            .ToDictionary(x => x.IdEquipo, x => x.Cantidad);
    }

    private int ObtenerCantidadJugadores(int idEquipo)
    {
        return jugadoresPorEquipo.TryGetValue(idEquipo, out var cantidad) ? cantidad : 0;
    }

    private void MostrarFormularioNuevo()
    {
        formModel = new EquipoFormModel();
        modoEdicion = false;
        mostrarFormulario = true;
        mensajeError = null;
        mensajeExito = null;
        idPendienteEliminar = null;
    }

    private void EditarEquipo(Equipo equipo)
    {
        formModel = new EquipoFormModel
        {
            ID_Equipo = equipo.ID_Equipo,
            Nombre_Equipo = equipo.Nombre_Equipo,
            Categoria = equipo.Categoria,
            Logo = equipo.Logo
        };
        modoEdicion = true;
        mostrarFormulario = true;
        mensajeError = null;
        mensajeExito = null;
        idPendienteEliminar = null;
    }

    private void CancelarFormulario()
    {
        mostrarFormulario = false;
        mensajeError = null;
    }

    private async Task GuardarEquipo()
    {
        mensajeError = null;

        if (string.IsNullOrWhiteSpace(formModel.Nombre_Equipo))
        {
            mensajeError = "Debes ingresar el nombre del equipo.";
            return;
        }

        if (!formModel.Nombre_Equipo.Any(char.IsLetter))
        {
            mensajeError = "El nombre del equipo debe contener al menos una letra.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(formModel.Logo) && !EsUrlValida(formModel.Logo))
        {
            mensajeError = "La URL del logo no es válida. Debe ser una imagen PNG (terminar en .png) y comenzar con http:// o https://";
            return;
        }

        bool nombreDuplicado = DbContext.Equipos
            .Any(e => e.Nombre_Equipo.ToLower() == formModel.Nombre_Equipo.Trim().ToLower()
                      && e.ID_Equipo != formModel.ID_Equipo);

        if (nombreDuplicado)
        {
            mensajeError = "Ya existe un equipo con ese nombre.";
            return;
        }

        if (modoEdicion)
        {
            var equipo = DbContext.Equipos.FirstOrDefault(e => e.ID_Equipo == formModel.ID_Equipo);
            if (equipo == null)
            {
                mensajeError = "El equipo que intentas editar ya no existe.";
                return;
            }

            equipo.Nombre_Equipo = formModel.Nombre_Equipo.Trim();
            equipo.Categoria = formModel.Categoria;
            equipo.Logo = formModel.Logo;
        }
        else
        {
            var nuevoEquipo = new Equipo
            {
                Nombre_Equipo = formModel.Nombre_Equipo.Trim(),
                Categoria = formModel.Categoria,
                Logo = formModel.Logo,
                ID_Usuario = Sesion.ID_Usuario!.Value
            };

            DbContext.Equipos.Add(nuevoEquipo);
        }

        await DbContext.SaveChangesAsync();

        mensajeExito = modoEdicion ? "Equipo actualizado exitosamente." : "Equipo registrado exitosamente.";
        mostrarFormulario = false;
        CargarEquipos();
    }

    private void SolicitarEliminarEquipo(int idEquipo)
    {
        idPendienteEliminar = idEquipo;
        mensajeError = null;
        mensajeExito = null;
    }

    private void CancelarEliminar()
    {
        idPendienteEliminar = null;
    }

    private async Task ConfirmarEliminarEquipo(int idEquipo)
    {
        mensajeError = null;
        mensajeExito = null;
        idPendienteEliminar = null;

        bool tieneJugadores = DbContext.Jugadores.Any(j => j.ID_Equipo == idEquipo);
        if (tieneJugadores)
        {
            mensajeError = "No se puede eliminar el equipo porque tiene jugadores registrados.";
            return;
        }

        bool tienePartidos = DbContext.Partidos.Any(p => p.Equipo_Local == idEquipo || p.Equipo_Visitante == idEquipo);
        if (tienePartidos)
        {
            mensajeError = "No se puede eliminar el equipo porque tiene partidos programados.";
            return;
        }

        var inscripciones = DbContext.Torneo_Equipo.Where(te => te.ID_Equipo == idEquipo);
        DbContext.Torneo_Equipo.RemoveRange(inscripciones);

        var equipo = DbContext.Equipos.FirstOrDefault(e => e.ID_Equipo == idEquipo);
        if (equipo != null)
        {
            DbContext.Equipos.Remove(equipo);
        }

        await DbContext.SaveChangesAsync();

        mensajeExito = "Equipo eliminado exitosamente.";
        CargarEquipos();
    }

    private bool EsUrlValida(string url)
    {
        if (!Uri.TryCreate(url.Trim(), UriKind.Absolute, out var uriResult)) return false;
        if (uriResult.Scheme != Uri.UriSchemeHttp && uriResult.Scheme != Uri.UriSchemeHttps) return false;
        return uriResult.AbsolutePath.EndsWith(".png", StringComparison.OrdinalIgnoreCase);
    }

    private bool LogoEsValido(string? url)
    {
        return !string.IsNullOrWhiteSpace(url) && EsUrlValida(url);
    }

    private void VolverPanel()
    {
        Navigation.NavigateTo("/principal");
    }
}
